# Groq API key — get yours free at console.groq.com (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here

# Groq model — llama-3.3-70b-versatile is free and performs well
GROQ_MODEL=llama-3.3-70b-versatile

# MySQL connection string
# Local development:
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/recipesbyiq_db
# PlanetScale (free cloud MySQL for deployment):
# DATABASE_URL=mysql+pymysql://username:password@host.psdb.cloud/recipesbyiq_db?ssl_ca=/etc/ssl/cert.pem

# Maximum number of ingredients per request
MAX_INGREDIENTS=20
